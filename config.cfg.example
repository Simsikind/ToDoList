; Example configuration for ToDoList
; Copy to config.cfg and adjust values.
; NOTE: config.cfg is gitignored because it contains secrets.

[database]
host = localhost
port = 5432
dbname = todo_db
user = todo_user
password = ChangeME!
sslmode = prefer

[security]
; JWT signing secret (required). Use a long random string.
; Alternative: set environment variable TODO_JWT_SECRET
jwt_secret = ChangeME-Long-Random-Secret

[printer]
enable = true
prntname = Generic / Text Only

[app]
base_url = https://todo.example.org
; Optional: default timezone for new users
default_timezone = UTC
